# ============================================
# TRAVEL MARAJO - VARIAVEIS DE AMBIENTE
# ============================================
# Copie este arquivo para .env.local e preencha os valores

# --------------------------------------------
# DATABASE (Railway, Supabase, Neon, etc)
# --------------------------------------------
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# --------------------------------------------
# NEXTAUTH.JS (Autenticacao)
# --------------------------------------------
# Gere uma chave secreta: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --------------------------------------------
# GOOGLE OAUTH (Login com Google)
# --------------------------------------------
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="seu-client-id-do-google.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret-do-google"

# --------------------------------------------
# STRIPE (Pagamentos)
# --------------------------------------------
# Crie em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_sua-chave-secreta-stripe"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_sua-chave-publica-stripe"
STRIPE_WEBHOOK_SECRET="whsec_seu-webhook-secret"

# --------------------------------------------
# AMADEUS API (Busca de Voos)
# --------------------------------------------
# Crie em: https://developers.amadeus.com/
AMADEUS_API_KEY="sua-api-key-amadeus"
AMADEUS_API_SECRET="sua-api-secret-amadeus"
AMADEUS_BASE_URL="https://test.api.amadeus.com"

# --------------------------------------------
# EMAIL (SendGrid, Mailgun, etc)
# --------------------------------------------
EMAIL_SERVER_USER="apikey"
EMAIL_SERVER_PASSWORD="sua-api-key-sengrid"
EMAIL_SERVER_HOST="smtp.sendgrid.net"
EMAIL_SERVER_PORT="587"
EMAIL_FROM="noreply@travelmarajo.com"

# --------------------------------------------
# CLOUDINARY (Upload de Imagens)
# --------------------------------------------
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="sua-api-secret"

# --------------------------------------------
# GOOGLE ANALYTICS
# --------------------------------------------
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --------------------------------------------
# BOOKING.COM API (RapidAPI)
# --------------------------------------------
BOOKING_COM_API_KEY="sua-chave-rapidapi"
BOOKING_COM_API_URL="https://booking-com15.p.rapidapi.com/api/v1"

# --------------------------------------------
# OPERATIONS / RUNBOOK
# --------------------------------------------
OPS_RUNBOOK_TOKEN="troque-por-um-token-longo-e-seguro"

# --------------------------------------------
# I18N / ROUTING
# --------------------------------------------
# Locales suportados no path: /pt, /en, /es, /fr
# A canonicalizacao de rotas usa NEXT_PUBLIC_SITE_URL ou NEXTAUTH_URL
